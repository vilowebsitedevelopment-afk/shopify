<section class="trust-highlights">
  {% for block in section.blocks %}
    <article class="trust-item" {{ block.shopify_attributes }}>
      <span>{{ block.settings.label }}</span>
      <h3>{{ block.settings.heading }}</h3>
      <p>{{ block.settings.text }}</p>
    </article>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Trust highlights",
  "settings": [],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Care"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Pet-first picks"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Products chosen for comfort, play, and everyday care."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust highlights",
      "blocks": [
        {
          "type": "highlight",
          "settings": {
            "label": "Care",
            "heading": "Pet-first picks",
            "text": "Products chosen for comfort, play, and everyday care."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "label": "Fast",
            "heading": "Easy shopping",
            "text": "Simple browsing so customers can find essentials quickly."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "label": "Fresh",
            "heading": "New finds",
            "text": "Room to feature seasonal items, bundles, and new arrivals."
          }
        }
      ]
    }
  ]
}
{% endschema %}
