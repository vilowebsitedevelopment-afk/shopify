<section class="pet-categories">
  <div class="section-heading">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <p>{{ section.settings.text }}</p>
    {% endif %}
  </div>

  <div class="category-grid">
    {% for block in section.blocks %}
      <a class="category-card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
        <span class="category-card__icon">{{ block.settings.icon }}</span>
        <h3>{{ block.settings.title }}</h3>
        <p>{{ block.settings.text }}</p>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Pet categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by pet need"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Find everyday essentials, playful extras, and care products for your favorite companion."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "Paw"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Dog supplies"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Food, toys, collars, beds, and daily dog essentials."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pet categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "icon": "Dog",
            "title": "Dog supplies",
            "text": "Food, toys, collars, beds, and daily dog essentials.",
            "link": "/collections/all"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "Cat",
            "title": "Cat supplies",
            "text": "Scratchers, treats, litter tools, toys, and cozy favorites.",
            "link": "/collections/all"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "Treats",
            "title": "Treats",
            "text": "Rewards, snacks, chews, and tasty training helpers.",
            "link": "/collections/all"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "Toys",
            "title": "Toys",
            "text": "Fetch toys, plush favorites, puzzles, and playtime picks.",
            "link": "/collections/all"
          }
        }
      ]
    }
  ]
}
{% endschema %}
