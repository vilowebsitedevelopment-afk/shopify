<section class="circle-showcase">
  <div class="section-heading section-heading--center">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <p>{{ section.settings.text }}</p>
    {% endif %}
  </div>

  <div class="circle-grid">
    {% for block in section.blocks %}
      <a class="circle-card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
        <span class="circle-card__media">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 420 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {% else %}
            <img
              src="{{ 'claws-paws-logo.png' | asset_url }}"
              alt=""
              width="420"
              height="420"
              loading="lazy"
            >
          {% endif %}
        </span>
        <span class="circle-card__title">{{ block.settings.title }}</span>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Circle showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse favorites"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Quickly jump into the pet categories customers shop most."
    }
  ],
  "blocks": [
    {
      "type": "circle",
      "name": "Circle item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback_text",
          "label": "Fallback text",
          "default": "Pet"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pet toys"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Circle showcase",
      "blocks": [
        {
          "type": "circle",
          "settings": {
            "fallback_text": "Dog",
            "title": "Dog favorites",
            "link": "/collections/all"
          }
        },
        {
          "type": "circle",
          "settings": {
            "fallback_text": "Cat",
            "title": "Cat favorites",
            "link": "/collections/all"
          }
        },
        {
          "type": "circle",
          "settings": {
            "fallback_text": "Treats",
            "title": "Treats",
            "link": "/collections/all"
          }
        },
        {
          "type": "circle",
          "settings": {
            "fallback_text": "Care",
            "title": "Grooming",
            "link": "/collections/all"
          }
        },
        {
          "type": "circle",
          "settings": {
            "fallback_text": "Beds",
            "title": "Beds",
            "link": "/collections/all"
          }
        }
      ]
    }
  ]
}
{% endschema %}
