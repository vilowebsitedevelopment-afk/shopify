<section class="brand-story">
  <div class="brand-story__media">
    {{ 'claws-paws-logo.png' | asset_url | image_tag: alt: shop.name }}
  </div>

  <div class="brand-story__content">
    {% if section.settings.eyebrow != blank %}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <p>{{ section.settings.text }}</p>
    {% endif %}

    <div class="brand-story__points">
      {% for block in section.blocks %}
        <article {{ block.shopify_attributes }}>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small heading",
      "default": "Claws & Paws"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Love, care, and family for every pet."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Claws & Paws is built around simple, thoughtful shopping for pets and the people who love them."
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Story point",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Premium quality"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Curated essentials for comfort, play, wellness, and daily routines."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand story",
      "blocks": [
        {
          "type": "point",
          "settings": {
            "heading": "Premium quality",
            "text": "Curated essentials for comfort, play, wellness, and daily routines."
          }
        },
        {
          "type": "point",
          "settings": {
            "heading": "Pet-lover approved",
            "text": "A warm shopping experience designed for dogs, cats, and happy homes."
          }
        }
      ]
    }
  ]
}
{% endschema %}
