<header class="site-header">
  <a class="site-logo" href="{{ routes.root_url }}">
    {% if section.settings.logo != blank %}
      {{ section.settings.logo | image_url: width: 240 | image_tag: alt: shop.name, class: 'site-logo__image' }}
    {% else %}
      <img
        class="site-logo__image"
        src="{{ 'claws-paws-logo.png' | asset_url }}"
        alt="{{ shop.name }}"
        width="120"
        height="120"
      >
    {% endif %}
    <span class="site-logo__text">{{ shop.name }}</span>
  </a>

  <nav class="site-nav" aria-label="Main navigation">
    <a href="{{ routes.root_url }}">Home</a>
    <a href="{{ routes.all_products_collection_url }}">Shop</a>
    <a href="{{ routes.cart_url }}">Cart</a>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}
